rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Función auxiliar: verifica si el usuario es admin ──
    // Los admins se registran en la colección "admins/{uid}"
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Colección de admins: solo lectura para el propio admin ──
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // se crean manualmente desde la consola de Firebase
    }

    // ── Catálogo de productos ──
    // Lectura pública; escritura solo admins (o seed inicial permitido)
    match /products/{productId} {
      allow read: if true;
      allow create: if true;           // permite el seed inicial desde el cliente
      allow update: if isAdmin() ||
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['stock']);
      allow delete: if isAdmin();
    }

    // ── Perfil de usuario y wishlist ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();        // admin puede ver perfiles
    }

    // ── Pedidos ──
    // Cualquiera puede crear (checkout de invitado);
    // el dueño puede leer el suyo; admin puede leer y actualizar todos.
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if isAdmin() ||
                       (request.auth != null && request.auth.uid == resource.data.uid);
      allow update: if isAdmin();      // admin actualiza estado del pedido
      allow delete: if false;
    }

    // ── Newsletter ──
    // Cualquiera puede suscribirse; solo admin puede listar suscriptores.
    match /subscribers/{subId} {
      allow create: if true;
      allow read:   if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Reseñas ──
    // Lectura pública; solo el autor puede crear/editar la suya; admin puede borrar.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null &&
                       request.auth.uid == resource.data.uid;
      allow delete: if isAdmin() ||
                       (request.auth != null && request.auth.uid == resource.data.uid);
    }

    // ── Métricas / KPIs del dashboard ──
    // Solo admin puede leer y escribir.
    match /metrics/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
